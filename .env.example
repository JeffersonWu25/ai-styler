OPENAI_API_KEY=sk-your-key-here
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1024

# Railway Postgres (public URL). Paste from Railway → your Postgres service → Connect.
# Use the public host (*.railway.app), not *.railway.internal.
# DATABASE_SSL_VERIFY=false is the default and works for Railway from a local Mac.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/railway

JWT_SECRET=change-me-to-a-long-random-string

# Railway Storage Bucket (S3-compatible). Paste from Railway → Storage → Credentials.
S3_ENDPOINT=https://your-bucket-endpoint
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=auto
